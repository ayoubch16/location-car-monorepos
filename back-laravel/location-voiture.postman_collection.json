              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api","users"] }
          }
        },

        {
          "name": "Modifier user (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telephone\": \"0699887766\",\n  \"adresse\": \"8 Rue Ibn Battouta, Fès\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/users/1", "host": ["{{base_url}}"], "path": ["api","users","1"] }
          }
        },

        {
          "name": "Supprimer user (admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/users/1", "host": ["{{base_url}}"], "path": ["api","users","1"] }
          }
        }

      ]
    },

    {
      "name": "Profil",
      "item": [

        {
          "name": "Modifier mon profil",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Benali\",\n  \"prenom\": \"Youssef\",\n  \"telephone\": \"0655443322\",\n  \"adresse\": \"20 Rue Mohammed V, Rabat\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/profile", "host": ["{{base_url}}"], "path": ["api","profile"] }
          }
        }

      ]
    }

  ]
}
